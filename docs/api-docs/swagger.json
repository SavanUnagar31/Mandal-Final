{
  "openapi": "3.0.0",
  "info": {
    "title": "Mandal Backend API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "summary": "Register a user",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "mobile": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered" }
        }
      }
    },
    "/api/v1/mandals": {
      "post": {
        "summary": "Create a mandal",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "contributionMode": { "type": "string" },
                  "contributionAmount": { "type": "number" },
                  "interestRate": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Mandal created" }
        }
      }
    }
  }
}